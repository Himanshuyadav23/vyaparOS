rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own profile and other users' public info
      allow read: if isAuthenticated();
      
      // Users can create their own profile
      allow create: if isAuthenticated() && 
        isOwner(userId) &&
        request.resource.data.uid == userId &&
        request.resource.data.uid == request.auth.uid;
      
      // Users can update their own profile
      allow update: if isOwner(userId) &&
        request.resource.data.uid == userId; // Prevent uid changes
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }
    
    // Shops collection
    match /shops/{shopId} {
      // All authenticated users can read shops
      allow read: if isAuthenticated();
      
      // Users can create shops they own
      allow create: if isAuthenticated() &&
        request.resource.data.ownerId == request.auth.uid;
      
      // Only shop owner can update
      allow update: if isAuthenticated() &&
        (resource.data.ownerId == request.auth.uid || isAdmin());
      
      // Only shop owner or admin can delete
      allow delete: if isAuthenticated() &&
        (resource.data.ownerId == request.auth.uid || isAdmin());
    }
    
    // Products collection (master catalog)
    match /products/{productId} {
      // All authenticated users can read products
      allow read: if isAuthenticated();
      
      // Only admins can create/update/delete products (master catalog)
      allow create, update, delete: if isAdmin();
    }
    
    // Dead Stock Listings
    match /deadStockListings/{listingId} {
      // All authenticated users can read available listings
      allow read: if isAuthenticated();
      
      // Users can create their own listings
      allow create: if isAuthenticated() &&
        request.resource.data.sellerId == request.auth.uid &&
        request.resource.data.status == 'available';
      
      // Sellers can update their own listings
      allow update: if isAuthenticated() &&
        (resource.data.sellerId == request.auth.uid || isAdmin()) &&
        // Prevent changing sellerId
        request.resource.data.sellerId == resource.data.sellerId;
      
      // Sellers can delete their own listings
      allow delete: if isAuthenticated() &&
        (resource.data.sellerId == request.auth.uid || isAdmin());
    }
    
    // Catalog Items
    match /catalogItems/{catalogId} {
      // All authenticated users can read active catalog items
      allow read: if isAuthenticated();
      
      // Suppliers can create their own catalog items
      allow create: if isAuthenticated() &&
        request.resource.data.supplierId == request.auth.uid;
      
      // Suppliers can update their own catalog items
      allow update: if isAuthenticated() &&
        (resource.data.supplierId == request.auth.uid || isAdmin()) &&
        // Prevent changing supplierId
        request.resource.data.supplierId == resource.data.supplierId;
      
      // Suppliers can delete their own catalog items
      allow delete: if isAuthenticated() &&
        (resource.data.supplierId == request.auth.uid || isAdmin());
    }
    
    // Ledger Transactions
    match /ledgerTransactions/{transactionId} {
      // Users can read transactions where they are creditor or debtor
      allow read: if isAuthenticated() &&
        (resource.data.creditorId == request.auth.uid ||
         resource.data.debtorId == request.auth.uid ||
         isAdmin());
      
      // Creditors can create transactions
      allow create: if isAuthenticated() &&
        request.resource.data.creditorId == request.auth.uid &&
        request.resource.data.status == 'pending';
      
      // Creditor or debtor can update (for status changes, payments)
      allow update: if isAuthenticated() &&
        ((resource.data.creditorId == request.auth.uid ||
          resource.data.debtorId == request.auth.uid ||
          isAdmin()) &&
         // Prevent changing creditorId or debtorId
         request.resource.data.creditorId == resource.data.creditorId &&
         request.resource.data.debtorId == resource.data.debtorId);
      
      // Only creditor or admin can delete
      allow delete: if isAuthenticated() &&
        (resource.data.creditorId == request.auth.uid || isAdmin());
    }
    
    // Inquiries
    match /inquiries/{inquiryId} {
      // Buyers and sellers can read their inquiries
      allow read: if isAuthenticated() &&
        (resource.data.buyerId == request.auth.uid ||
         resource.data.sellerId == request.auth.uid ||
         isAdmin());
      
      // Buyers can create inquiries
      allow create: if isAuthenticated() &&
        request.resource.data.buyerId == request.auth.uid &&
        request.resource.data.status == 'pending';
      
      // Buyers and sellers can update inquiries
      allow update: if isAuthenticated() &&
        ((resource.data.buyerId == request.auth.uid ||
          resource.data.sellerId == request.auth.uid ||
          isAdmin()) &&
         // Prevent changing buyerId or sellerId
         request.resource.data.buyerId == resource.data.buyerId &&
         request.resource.data.sellerId == resource.data.sellerId);
      
      // Buyers can delete their own inquiries
      allow delete: if isAuthenticated() &&
        (resource.data.buyerId == request.auth.uid || isAdmin());
    }
    
    // Market Stats (read-only for regular users)
    match /marketStats/{statId} {
      // All authenticated users can read market stats
      allow read: if isAuthenticated();
      
      // Only system/admin can create/update market stats
      // In production, this would be done via Cloud Functions or Admin SDK
      allow create, update, delete: if false;
    }
    
    // Legacy collections (for backward compatibility)
    match /deadStock/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.sellerId == request.auth.uid;
    }
    
    match /catalog/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.supplierId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.supplierId == request.auth.uid;
    }
    
    match /creditTransactions/{transactionId} {
      allow read: if isAuthenticated() &&
        (resource.data.creditorId == request.auth.uid ||
         resource.data.debtorId == request.auth.uid);
      allow create: if isAuthenticated() &&
        request.resource.data.creditorId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.creditorId == request.auth.uid ||
         resource.data.debtorId == request.auth.uid);
      allow delete: if isAuthenticated() &&
        resource.data.creditorId == request.auth.uid;
    }
    
    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }
    
    match /marketSignals/{signalId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }
  }
}
